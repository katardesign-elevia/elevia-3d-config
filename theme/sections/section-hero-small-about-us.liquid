<style>
  .hero-image.show-on-mobile { display: none; }
  .hero-image.hide-on-mobile { display: block; }
  @media (max-width: 767px) {
    .hero-image.show-on-mobile { display: block; }
    .hero-image.hide-on-mobile { display: none; }
  }
</style>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const slides = [
      document.querySelector(".hero-slide.is-wellness"),
      document.querySelector(".hero-slide.is-vibe"),
      document.querySelector(".hero-slide.is-medical")
    ];
    const dots = document.querySelectorAll(".dot");
    const loadingBar = document.querySelector(".loading-bar");
    const heroWrapper = document.querySelector(".home-hero-wrapper");

    let currentIndex = 0;

    function setStyles(el, styles) {
      for (const prop in styles) {
        el.style[prop] = styles[prop];
      }
    }

    function startLoadingBar() {
      setStyles(loadingBar, { transition: "none", width: "0%" });
      requestAnimationFrame(() => {
        setTimeout(() => {
          setStyles(loadingBar, { transition: "width 6s linear", width: "100%" });
        }, 20);
      });
    }

    function showSlide(index) {
      slides.forEach((slide, i) => {
        if (i === index) {
          setStyles(slide, { display: "block", opacity: "0", transition: "opacity 0.5s ease-out" });
          requestAnimationFrame(() => setStyles(slide, { opacity: "1" }));
        }
      });

      setStyles(heroWrapper, { transform: "translateX(24px)" });
      setTimeout(() => {
        setStyles(heroWrapper, {
          transition: "transform 0.6s ease-out",
          transform: "translateX(0px)"
        });
      }, 10);

      // dots
      dots.forEach((dot, i) => {
        setStyles(dot, {
          transition: "width 0.6s ease-out, background-color 0.6s ease-out",
          width: i === index ? "56px" : "8px",
          backgroundColor: i === index ? "white" : "rgba(255,255,255,0.7)"
        });
      });
    }

    function hidePreviousSlide(prevIndex) {
      const prevSlide = slides[prevIndex];
      setStyles(prevSlide, { transition: "opacity 0.6s ease-out", opacity: "0" });
      setTimeout(() => {
        setStyles(prevSlide, { display: "none" });
      }, 600);
    }

    function nextSlide() {
      const prevIndex = currentIndex;
      currentIndex = (currentIndex + 1) % slides.length;

      hidePreviousSlide(prevIndex);
      showSlide(currentIndex);
      startLoadingBar();
    }

    function init() {
      // Start first slide
      slides.forEach((slide, i) => {
        setStyles(slide, {
          display: i === 0 ? "block" : "none",
          opacity: i === 0 ? "1" : "0"
        });
      });

      dots.forEach((dot, i) => {
        setStyles(dot, {
          width: i === 0 ? "56px" : "8px",
          backgroundColor: i === 0 ? "white" : "rgba(255,255,255,0.7)"
        });
      });

      startLoadingBar();

      setInterval(() => {
        nextSlide();
      }, 6000);
    }

    init();
  });
</script>























