<div class="home-hero">
  <div class="loading-bar-wrapper">
    <div class="loading-bar"></div>
  </div>
  <div class="dots-wrapper">
    <div class="dot"></div>
    <div class="dot"></div>
    <div class="dot"></div>
  </div>

    <div class="hero-slide is-wellness">
    <img src="{{ section.settings.slide_1_image.src | img_url: 'master' }}" 
        loading="eager" 
        alt="{{ section.settings.slide_1_image.alt | escape }}" 
        class="hero-image hide-on-mobile">

    {%- if section.settings.slide_1_image_mobile != blank -%}
      <img src="{{ section.settings.slide_1_image_mobile.src | img_url: 'master' }}" 
          loading="eager" 
          alt="{{ section.settings.slide_1_image_mobile.alt | escape }}" 
          class="hero-image show-on-mobile">
    {%- endif -%}

    <div class="w-layout-blockcontainer container-small is-home w-container">
