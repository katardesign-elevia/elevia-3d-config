                  <script>
function validateInput(input) {
  const value = input.value.trim();
  const type = input.getAttribute("type") || input.tagName.toLowerCase();
  if (value === "") {
    return { isValid: false, isEmpty: true };
  }
  let isValid = true;
  if (type === "text") {
    isValid = value.length >= 2;
  } else if (type === "email") {
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    isValid = emailRegex.test(value);
  } else if (type === "tel" || input.getAttribute("name") === "Phone-number") {
    const phoneRegex = /^\d{7,15}$/; // Min. 7 číslic, max. 15
    isValid = phoneRegex.test(value);
  } else if (type === "textarea") {
    isValid = value.length >= 3;
  }
  return { isValid, isEmpty: false };
}
function setValidationState(input, isValid, isEmpty) {
  const label = input.nextElementSibling; // Předpokládáme, že label je hned za inputem
  const iconSuccess = input.parentElement.querySelector(".icon-success");
  const iconError = input.parentElement.querySelector(".icon-error");
  const textError = input.parentElement.querySelector(".text-error");
  input.classList.remove("error", "success");
  label.classList.remove("error", "success");
  if (iconSuccess) iconSuccess.style.display = "none";
  if (iconError) iconError.style.display = "none";
  if (textError) textError.style.display = "none";
  if (isEmpty) {
    return;
  }
  if (isValid) {
    input.classList.add("success");
    label.classList.add("success");
    if (iconSuccess) iconSuccess.style.display = "block";
  } else {
    input.classList.add("error");
    label.classList.add("error");
    if (iconError) iconError.style.display = "block";
    if (textError) textError.style.display = "block";
  }
}
function handleBlur(event) {
  const input = event.target;
  const { isValid, isEmpty } = validateInput(input);
  setValidationState(input, isValid, isEmpty);
}
document.querySelectorAll(".form-input").forEach(input => {
  input.addEventListener("blur", handleBlur);
});
</script>
