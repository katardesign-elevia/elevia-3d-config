
    <div class="w-layout-blockcontainer container-small w-container">
      <div class="flex-default">
        <div class="elevia-benefits">
          <div class="benefit-wrapper">{%- if section.settings.column_1_image == nil -%}<img src="{{ 'fast-delivery.svg' | asset_url }}" loading="lazy" alt="" class="benefit-icon">{%- else -%}<img src="{{ section.settings.column_1_image.src | img_url: 'master' }}" loading="lazy" alt="{{ section.settings.column_1_image.alt | escape }}" class="benefit-icon">{%- endif -%}
            <div class="benefit-block">
              <h2 class="all-caps text-align-center two-rows">{{ section.settings.column_1_headline }}</h2>
              <div p-add-class="text-align-center">{{ section.settings.column_1_description | newline_to_br }}</div>
            </div>
          </div>
          <div class="benefit-wrapper">{%- if section.settings.column_2_image == nil -%}<img src="{{ 'free-sample.svg' | asset_url }}" loading="lazy" alt="" class="benefit-icon">{%- else -%}<img src="{{ section.settings.column_2_image.src | img_url: 'master' }}" loading="lazy" alt="{{ section.settings.column_2_image.alt | escape }}" class="benefit-icon">{%- endif -%}
            <div class="benefit-block">
              <h2 class="all-caps text-align-center two-rows">{{ section.settings.column_2_headline }}</h2>
              <div p-add-class="text-align-center">{{ section.settings.column_2_description | newline_to_br }}</div>
            </div>
          </div>
          <div class="benefit-wrapper">{%- if section.settings.column_3_image == nil -%}<img src="{{ 'made-in-czechia.svg' | asset_url }}" loading="lazy" alt="" class="benefit-icon">{%- else -%}<img src="{{ section.settings.column_3_image.src | img_url: 'master' }}" loading="lazy" alt="{{ section.settings.column_3_image.alt | escape }}" class="benefit-icon">{%- endif -%}
            <div class="benefit-block">
              <h2 class="all-caps text-align-center two-rows">{{ section.settings.column_3_headline }}</h2>
              <div p-add-class="text-align-center">{{ section.settings.column_3_description | newline_to_br }}</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  

<script>var currentSection = document.currentScript.closest('.shopify-section');currentSection.setAttribute("class","section-default");</script>
        
{% schema %}
{
  "name": "Section - USP",
  "tag": "section",
  "class": "section-default",
  "settings": [
    {
      "type": "richtext",
      "id": "column_1_description",
      "label": "Column 1 - Description",
      "default": "<p>We deliver within the next working day because we want to give you a unique experience.</p>"
    },
    {
      "type": "richtext",
      "id": "column_2_description",
      "label": "Column 2 - Description",
      "default": "<p>For every order over CZK 1500 you will get a unique sample for free.</p>"
    },
    {
      "type": "richtext",
      "id": "column_3_description",
      "label": "Column 3 - Description",
      "default": "<p>We are a Czech company and our growing and production takes place exclusively in the Czech.</p>"
    },
    {
      "type": "text",
      "id": "column_3_headline",
      "label": "Column 3 - Headline",
      "default": "made in "
    },
    {
      "type": "text",
      "id": "column_2_headline",
      "label": "Column 2 - Headline",
      "default": "Sample Text"
    },
    {
      "type": "text",
      "id": "column_1_headline",
      "label": "Column 1 - Headline",
      "default": "Sample Text"
    },
    {
      "type": "image_picker",
      "id": "column_3_image",
      "label": "Column 3 - Image"
    },
    {
      "type": "image_picker",
      "id": "column_2_image",
      "label": "Column 2 - Image"
    },
    {
      "type": "image_picker",
      "id": "column_1_image",
      "label": "Column 1 - Image"
    }
  ]
}
{% endschema %}