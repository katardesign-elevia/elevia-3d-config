  assign dosage_1_content = product.metafields.custom.sekce_davkovani_obsah_bloku_1 | default: section.settings.dosage_1_content
  assign dosage_2_headline = product.metafields.custom.sekce_davkovani_nadpis_bloku_2 | default: section.settings.dosage_2_headline
  assign dosage_2_content = product.metafields.custom.sekce_davkovani_obsah_bloku_2 | default: section.settings.dosage_2_content
  assign dosage_3_headline = product.metafields.custom.sekce_davkovani_nadpis_bloku_3 | default: section.settings.dosage_3_headline
  assign dosage_3_content = product.metafields.custom.sekce_davkovani_obsah_bloku_3 | default: section.settings.dosage_3_content
