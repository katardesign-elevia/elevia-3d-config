{%- liquid
  assign light_color = product.metafields.custom['light-color'] | default: section.settings.light_color
  assign bg_color = product.metafields.custom['bg-color'] | default: section.settings.bg_color

  assign product_subtitle = product.metafields.custom.hero_sekce_podnadpis_produktu | default: section.settings.product_subtitle
  assign product_volume = product.metafields.custom.hero_sekce_objem | default: section.settings.product_volume
  assign product_concentration = product.metafields.custom.hero_sekce_koncentrace | default: section.settings.product_concentration
  assign product_thc = product.metafields.custom.hero_sekce_obsah_thc | default: section.settings.product_thc

  assign scroll_text_1 = product.metafields.custom.animovany_posuvny_text_prvni_radek | default: section.settings.scroll_text_1
