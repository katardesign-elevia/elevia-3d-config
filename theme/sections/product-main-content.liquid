<section class="light-section" id="product-faq-{{ product.id | handleize }}">
  {%- assign product_faq_list = product.metafields.custom.faq_seznam.value -%}

  {% if product_faq_list != blank %}
    <div class="w-layout-blockcontainer container-small w-container">
      <div class="faq-headline-wrapper">
        <h4 class="text-style-caps no-shrink is-faq">
          {%- if product.metafields.custom.faq_nadpis != blank -%}
            {{- product.metafields.custom.faq_nadpis | metafield_tag -}}
          {%- else -%}
            {{ 't11818' | t }}<span class="text-underline">{{ 'td37612d' | t }}</span>
          {%- endif -%}
        </h4>
        <p class="body-medium">
          {{ 't3639bca4' | t }}<br />{{ 'tn1d8de2a7' | t }}
        </p>
      </div>

      <div class="faq-main-wrapper">
        <div role="list" class="faq-list">
          {% for faq_item in product_faq_list %}
            <div
              data-w-id="1903e811-7c59-bb39-779c-9615c1ac25df"
              role="listitem"
              class="faq-wrapper w-dyn-item {% if forloop.index > 5 %}is-hidden{% endif %}"
            >
              <div id="showmore" class="faq-question-wrapper">
                <div class="faq-number"></div>
                <div class="faq-answer-wrapper">
                  <div class="body-large">{{ faq_item.question.value }}</div>
                  <p class="body-small">{{ faq_item.answer.value }}</p>
                </div>
              </div>
              <div class="icon-faq_wrapper">
                <div class="icon-faq w-embed">
                  <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path
                      d="M5 10L11.2191 15.3306C11.6684 15.7158 12.3316 15.7158 12.7809 15.3306L19 10"
                      stroke="currentColor"
                      stroke-linecap="round"
                    />
                  </svg>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>

    {% comment %} Tlačítko je zde vykresleno vždy, ale skryté. JavaScript rozhodne, zda ho zobrazit. {% endcomment %}
    <div class="faq-button-wrapper is-hidden">
      <div class="button is-secondary showmore">
        <div class="button-text-faq">{{ 't284c678' | t }}</div>
        <div class="button-icon">
          <div class="icon-16 is-faq-icon w-embed">
            <svg
              width="16"
              height="16"
              viewBox="0 0 16 16"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M3.33203 7.9987H12.6654M12.6654 7.9987L7.9987 3.33203M12.6654 7.9987L7.9987 12.6654"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
              ></path>
            </svg>
          </div>
        </div>
      </div>
    </div>
  {% endif %}
</section>

<style>
  .faq-wrapper.is-hidden,
  .faq-button-wrapper.is-hidden {
    display: none;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const faqSection = document.querySelector('#product-faq-{{ product.id | handleize }}');
    if (!faqSection) return;

    const showMoreWrapper = faqSection.querySelector('.faq-button-wrapper');
    const showMoreButton = faqSection.querySelector('.showmore');
    const hiddenItems = faqSection.querySelectorAll('.faq-wrapper.is-hidden');

    // Zobrazíme tlačítko POUZE pokud existují skryté položky
    if (hiddenItems.length > 0) {
      showMoreWrapper.classList.remove('is-hidden');
    }

    if (showMoreButton) {
      showMoreButton.addEventListener('click', function() {
        hiddenItems.forEach(item => {
          item.classList.remove('is-hidden');
        });
        showMoreWrapper.style.display = 'none';
      });
    }
  });
</>

