                      <p class="body-medium all-caps text-color-white80">{{ related_product.type }}</p>
                    {% endif %}
                    <h2 class="all-caps text-align-center">{{ related_product.title }}</h2>
                  </div>
                  <div class="btn-card"><div class="btn-card is-hover"></div></div>
                </div>
              </a>
            {%- endfor -%}

            <div class="swiper-slide is-small-product hide">
              <div class="product-card-content is-last_product">
                <h2 class="all-caps text-align-center"><span class="is-underlined">{{ 't7bdffed0' | t }}</span><br>{{ 'tn3bd42e9c' | t }}</h2>
                <a href="#" class="button is-secondary w-inline-block">
