        <div data-w-id="4cecb2b0-f206-8f6d-e1a1-c8c798c48de9" class="next-sec1"></div>
        
        {%- assign related_products = product.metafields.custom.elevia_collection_produkty.value -%}
        
        {%- if related_products != blank -%}
          <div class="swiper-wrapper">
            {%- for related_product in related_products -%}
