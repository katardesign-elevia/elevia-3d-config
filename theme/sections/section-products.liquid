             class="image-products-hp">
    {%- endif -%}
<div class="text-color-light-gray text-weight-semibold mobile-padding">{{ 't601' | t }}</div>
<div class="products-hp-link-block">
<div class="text-80 all-caps is-product">{{ section.settings.row_1_headline }}</div>
<div class="button-wrapper-mask">
<div class="button-wrapper">
{% for i in (1..3) %}
{% assign link_key = 'row_1_link_' | append: i %}
{% assign button_key = 'row_1_button_' | append: i %}
<a href="{{ section.settings[link_key] | default: 'javascript:void(0);' }}" class="button w-inline-block" style="{% if section.settings[link_key] == blank %}pointer-events: none; cursor: default;{% endif %}">
