<img src="{% if section.settings[link_key] == blank %}{{ 'icon-button-disabled.svg' | asset_url }}{% else %}{{ 'icon-button_1.svg' | asset_url }}{% endif %}" loading="lazy" alt="" class="icon-button">
</a>
{% endfor %}
</div>
</div>
</div>
<div class="arrow-wrapper">
<div class="icon-24 w-embed"><svg width="25" height="24" viewbox="0 0 25 24" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M9.5 18L15.5 12L9.5 6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path>
</svg></div>
</div>
</div>
</div>{%- endif -%}

