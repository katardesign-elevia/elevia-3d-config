<!DOCTYPE html>

<html data-wf-page="{{ wfPage }}" data-wf-site="6690d2871e233e2bb8b7f4f2" lang="{{ request.locale.iso_code }}" data-money-format="{{ shop.money_with_currency_format | escape }}"><<head>{%- liquid
    if headerSnippetPath
        include headerSnippetPath
    else
        render "__default-head"
    endif
-%}
{{content_for_header}}
{% if template contains 'customers' %}
    {{ "shopify_common.js" | shopify_asset_url | script_tag }}
{% endif %}
</head>
<body class="{{ bodyClasses }} {{ "template-" | append: request.page_type | handle }}">
{% if headerSnippetPath %}
    {{ content_for_layout }}
{% else %}
    {% include "backup-layout" %}
{% endif %}

<script>
  document.addEventListener('DOMContentLoaded', function () {
      console.log("Script loaded successfully.");

      let isUpdating = false;  // Zabránění duplikovaným kliknutím

      function updateCartAjax(cartItem, change) {
          if (isUpdating) {
              console.warn("Update already in progress, skipping duplicate request.");
              return;
          }
          isUpdating = true;

          let quantityInput = cartItem.querySelector('.w-commerce-commercecartquantity');
          let currentValue = parseInt(quantityInput.value, 10) || 0;
          let newValue = currentValue + change;

          console.log(Current value: ${currentValue}, Change: ${change}, New value: ${newValue});

          if (newValue < 1) {
              console.warn("New quantity would be below 1, resetting to 1.");
              newValue = 1;
          }

          let itemId = quantityInput.getAttribute('name');

          fetch('/cart/change.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                  id: itemId,
                  quantity: newValue
              })
          })
          .then(response => response.json())
          .then(data => {
              console.log('Cart updated successfully:', data);
              updateCartSummary();
              updateCartItemCount();
              isUpdating = false;
          })
          .catch(error => {
              console.error('Error updating cart:', error);
              isUpdating = false;
          });
      }

      function updateCartSummary() {
          fetch('/cart.js')
              .then(response => response.json())
              .then(cart => {
                  document.querySelector('.w-commerce-commercecartordervalue').innerText = (cart.total_price / 100).toFixed(2) + ' Kč';
              });
      }

      function updateCartItemCount() {
          fetch('/cart.js')
              .then(response => response.json())
              .then(cart => {
                  let itemCountElement = document.querySelector('.w-commerce-commercecartopenlinkcount.cart-quantity');
                  if (itemCountElement) {
                      itemCountElement.innerText = cart.item_count;
                  }
              })
              .catch(error => console.error('Error updating cart count:', error));
      }

      function handleClick(e) {
          if (e.target.matches('[data-action="increment"], [data-action="decrement"]')) {
              e.preventDefault();

              let cartItem = e.target.closest('.cart-item');
              let change = e.target.dataset.action === "decrement" ? -1 : 1;

              console.log('Processing click for:', cartItem, 'Change:', change);
              updateCartAjax(cartItem, change);
          }
      }

      // Nejprve odstraníme předchozí event listenery (pokud existují), aby nedocházelo k duplikaci
      document.body.removeEventListener('click', handleClick);
      document.body.addEventListener('click', handleClick);

      updateCartSummary();
      updateCartItemCount();
  });
</script>














</body></html>