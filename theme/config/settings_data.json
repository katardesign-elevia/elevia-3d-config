      "section-faq-home": {
        "type": "section-faq-home",
        "blocks": {
          "faq_item_7apQhf": {
            "type": "faq_item",
            "settings": {
              "question": "Čím se vaše produkty liší od ostatních značek CBD?",
              "answer": "Celý proces - od genetiky a pěstování až po extrakci a složení - řídíme pomocí nejmodernějších technologií a metod. To zajišťuje bezkonkurenční konzistenci, čistotu a kvalitu."
            }
          },
          "faq_item_hy3GJc": {
            "type": "faq_item",
            "settings": {
              "question": "Jak zajišťujete kvalitu výrobků?",
              "answer": "Provádíme přísné kontroly kvality v každé fázi - od vizuálních kontrol během růstu až po kompletní analytické testování konečného produktu. Každá šarže je testována na přítomnost pesticidů, těžkých kovů a mikrobiálních kontaminantů."
            }
          },
          "faq_item_rynwnX": {
            "type": "faq_item",
            "settings": {
              "question": "Čím je váš proces extrakce výjimečný?",
              "answer": "Pro zachování maximální kvality uplatňujeme výrobní procesy probíhající za nízkého tlaku a při nízkých teplotách. Veškerá biomasa určená k extrakci prochází přísným testováním na přítomnost pesticidů, těžkých kovů a mikrobiálních kontaminantů."
            }
          },
          "faq_item_K8Km9D": {
            "type": "faq_item",
            "settings": {
              "question": "Jaké metody pěstování používáte?",
              "answer": "Naše rostliny pěstujeme v substrátu ROCKWOOL, který umožňuje přesnou kontrolu závlahy a živinných podmínek prostředí, což zajišťuje čistou úrodu bez plísní a s vysokým výnosem. Naše technologie nám umožňuje kontrolovat vnitřní klima s možností regulovat teplotu, vlhkost a intenzitu světelného záření."
            }
          },
          "faq_item_dNWrxJ": {
            "type": "faq_item",
            "settings": {
              "question": "Jsou vaše produkty vyrobeny z přírodních kanabinoidů?",
              "answer": "Rozhodně. Všechny naše produkty jsou vyrobeny z přírodních kanabinoidů získaných z našich vlastních rostlin, které jsou pěstovány za přísných kvalitativních standardů. V každé fázi výroby klademe důraz na čistotu a transparentnost a rozhodně se vyhýbáme jakýmkoli syntetickým látkám, přísadám nebo umělým sloučeninám. Získáte tak čistý, bezpečný a přírodní produkt, kterému můžete důvěřovat."
            }
          },
          "faq_item_4z93kz": {
            "type": "faq_item",
            "settings": {
              "question": "Jaké certifikáty používáte?",
