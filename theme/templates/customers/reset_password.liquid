{%- assign headerSnippetPath = "header-index" -%}{%- assign wfPage = "674b836e1349b6e88ac5aaa3" -%}{%- assign bodyClasses = "" -%}
  <div class="w-users-userformpagewrap">
    <div class="w-users-userupdatepasswordformwrapper">
      <div tabindex="-1" class="w-users-userformsuccessstate w-form-success">
        <div class="w-users-userformheader"><img src="https://d3e54v103j8qbb.cloudfront.net/img/thumbs-up-72.cbcaec93bc.svg" loading="lazy" alt="">
          <h2>{{ 'tn16704faa' | t }}</h2>
        </div>
        <p>{{ 't5284c470' | t }}</p>
        <a href="{{ routes.root_url }}" class="w-button">{{ 'tn27857705' | t }}</a>
      </div>
      {%- form "reset_customer_password",  class: "" -%}<form method="post" data-wf-user-form-type="updatePassword">
        <div class="w-users-userformheader">
          <h2>{{ 't69ed5012' | t }}</h2>
        </div>
        <p id="wf-update-password-paragraph">{{ 'tn2d35ed29' | t }}</p><label for="wf-update-password">{{ 't79707d5b' | t }}</label><input maxlength="256" placeholder="" name="customer[password]" id="wf-update-password" aria-describedby="wf-update-password-paragraph" class="w-input" type="password" required="" data-wf-user-form-input-type="password"><label for="customer[password_confirmation]">{{ 't4809999a' | t }}</label><input type="password" name="customer[password_confirmation]" class="w-input" required=""><input type="submit" data-wait="Please wait..." class="w-users-userformbutton w-button" value="{{ 't69ed5012' | t }}">
      {%- assign form_success = form.posted_successfully? -%}{%- assign form_errors = form.errors -%}{%- render "form-general-script", form_success: form_success, form_errors: form_errors -%}</form>{%- endform -%}
      {%- unless form_success -%}<div style="display:none" data-wf-user-form-error="true" class="w-users-userformerrorstate w-form-fail  {% if form.errors %}form-has-errors{% endif %}">
        <div class="user-form-error-msg" wf-update-pw-form-general-error-error="There was an error updating your password. Please try again, or contact us if you continue to have problems." wf-update-pw-form-weak-password-error="Your password must be at least 8 characters.">{%- render "form-errors", form_errors: form_errors -%}</div>
      </div>{%- endunless -%}
    </div>
  </div>
