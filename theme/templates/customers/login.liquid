{%- assign headerSnippetPath = "header-index" -%}{%- assign wfPage = "674b836e1349b6e88ac5aa81" -%}{%- assign bodyClasses = "body-login" -%}
  <div class="w-users-userformpagewrap page-wrapper">
    <div class="w-users-userloginformwrapper log-in-form-block">
      <div class="w-embed">
        <style>
  .form-input:focus + .form-label,
  .form-input:not(:placeholder-shown) + .form-label {
    top: 8px;
    font-size: 0.75rem;
    transform: translateY(0%);
  }
</style>
      </div>
      {%- form "customer_login",  class: "log-in-form" -%}<form class="log-in-form" data-wf-user-form-type="login" data-wf-user-form-redirect="/" method="post">
        <div class="w-users-userformheader">
          <h2 class="all-caps">{{ 'tn3bedbccc' | t }}<br>{{ 't7bdffed0' | t }}</h2>
        </div>
        <div class="from-input-wrapper">
          <div class="form-group"><input maxlength="256" placeholder="" name="customer[email]" id="wf-log-in-email" class="form-input w-input" type="email" autocomplete="username" required="" data-wf-user-form-input-type="email"><label for="email" class="form-label">{{ 't3ff5b7c' | t }}</label></div>
          <div class="form-group"><input maxlength="256" placeholder="" name="customer[password]" id="wf-log-in-password" class="form-input w-input" type="password" required="" data-wf-user-form-input-type="password"><label for="password" class="form-label">{{ 't4c641ebb' | t }}</label></div>
        </div>
        <div class="btn-login"><input type="submit" data-wait="Please wait..." class="w-users-userformbutton button is-secondary is-login w-button" value="{{ 'tn78042c3f' | t }}"><img id="w-node-aaa80c04-180b-a4bc-a4dd-055d4d76df93-8ac5aa81" loading="lazy" alt="" src="{{ 'icon-button.svg' | asset_url }}" class="icon-button is-contact"></div>
        <div class="w-users-userformfooter"><span>{{ 't7c95c01d' | t }}</span>
          <a href="{{ routes.account_register_url }}" class="login-link w-inline-block">{{ 'tn204ff822' | t }}</a>
        </div>
      {%- assign form_success = form.posted_successfully? -%}{%- assign form_errors = form.errors -%}{%- render "form-general-script", form_success: form_success, form_errors: form_errors -%}</form>{%- endform -%}
      {%- unless form_success -%}<div style="display:none" data-wf-user-form-error="true" class="w-users-userformerrorstate w-form-fail  {% if form.errors %}form-has-errors{% endif %}">
        <div class="user-form-error-msg" wf-login-form-general-error-error="We're having trouble logging you in. Please try again, or contact us if you continue to have problems." wf-login-form-invalid-email_or_password-error="Invalid email or password. Please try again.">{%- render "form-errors", form_errors: form_errors -%}</div>
      </div>{%- endunless -%}
    </div>
  </div>
  <script src="https://d3e54v103j8qbb.cloudfront.net/js/jquery-3.5.1.min.dc5e7f18c8.js?site=6690d2871e233e2bb8b7f4f2" type="text/javascript" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous"></script>
  <script src="{{ 'webflow.js' | asset_url }}" type="text/javascript"></script>
  <style>
	body { 	-webkit-font-smoothing: antialiased; 
				-moz-font-smoothing: antialiased; 
				-o-font-smoothing: antialiased;}
</style>
  <script>
$(document).ready(function() {
    var allowed = localStorage.getItem("allowed");
    if (allowed != 'true') {
        $('#age-parent').css('display', 'flex').hide().fadeIn(500);
        $('body').addClass('no-scroll'); 
    }
});
$("#over-age").click(function() {
    $('#age-parent').fadeOut(500, function() {
        localStorage.setItem("allowed", "true");
        $('body').removeClass('no-scroll');
    });
});
$("#under-age").click(function() {
    $('#error-box').fadeIn(500);
});
</script>
  <script defer="" src="https://cdn.jsdelivr.net/npm/@finsweet/attributes-scrolldisable@1/scrolldisable.js"></script>
  <style>
	.cart-wrapper{
  	height: 100vh;
    width: 100vw;
  }
</style>
  <!--  CUSTOM QUANTITY BUTTONS  -->
  <script src="https://cdn.jsdelivr.net/gh/CodeCrumbsApp/quantity-buttons@v0.1.4/index.min.js"></script>
  <script>
  window.CodeCrumbs.QuantityButtons({
    quantityGroupClass: 'q-group',
    quantityIncrementButtonClass: 'q-inc',
    quantityDecrementButtonClass: 'q-dec',
    quantityNumberFieldClass: 'q-num',
    disableDecrementAtOne: true,
  })
</script>

