</style>
  <script>
$(document).ready(function() {
    var allowed = localStorage.getItem("allowed");
    if (allowed != 'true') {
        // Zobrazí prvek a zakáže scrollování
        $('#age-parent').css('display', 'flex').hide().fadeIn(500);
        $('body').addClass('no-scroll'); // Zakáže scrollování
    }
});
$("#over-age").click(function() {
    $('#age-parent').fadeOut(500, function() {
        // Skryje prvek, povolí scrollování a nastaví souhlas do localStorage
        localStorage.setItem("allowed", "true");
        $('body').removeClass('no-scroll'); // Povolí scrollování
    });
});
$("#under-age").click(function() {
    $('#error-box').fadeIn(500);
});
</script>
