<script>

// Vybereme video element

const videoElement = document.querySelector('video');

// Funkce pro nastavení přehrávání videa podle scrollování

function setVideoProgress() {

const scrollTop = window.pageYOffset || document.documentElement.scrollTop;

const windowHeight = window.innerHeight;

const docHeight = document.documentElement.scrollHeight - windowHeight;

// Vypočítáme procento stránky, které uživatel poscrolloval

const scrollPercentage = scrollTop / docHeight;

// Nastavíme čas videa podle procenta scrolování

if (videoElement.duration) {

videoElement.currentTime = videoElement.duration * scrollPercentage;

}

}

// Funkce, která se spustí, když je video připraveno k přehrávání

function initVideoScrollPlayback() {

// Throttle pro optimalizaci počtu volání funkce při scrollování

let isScrolling;

window.addEventListener('scroll', function () {

// Zastavíme předchozí timeout a nastavíme nový

window.clearTimeout(isScrolling);

// Zavoláme funkci až po 100 ms od posledního scrollování

isScrolling = setTimeout(setVideoProgress, 100);

});

// Zajistíme, že se video začne přehrávat při interakci se stránkou

videoElement.play();

}

// Přidáme událost, která se spustí, když je video připravené

videoElement.addEventListener('canplaythrough', initVideoScrollPlayback);

// Pro případ, že by se událost nespustila, zajistíme fallback při načtení metadat

videoElement.addEventListener('loadedmetadata', setVideoProgress);

</script>

