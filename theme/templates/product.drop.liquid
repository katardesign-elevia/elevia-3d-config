<!-- faq numbers -->

<script>

function updateNumbers() {

document.querySelectorAll('.faq-wrapper').forEach((el, i) => {

const number = i + 1;

el.querySelector('.faq-number').textContent = number < 10 ? '0' + number : number;

});

}

updateNumbers();

document.querySelector('.w-pagination-next').addEventListener('click', function () {

setTimeout(updateNumbers, 0);

});

</script>

<!-- faq -->

<script>

document.addEventListener('DOMContentLoaded', function() {

let itemsToShow = 5;

const faqItems = document.querySelectorAll('.faq-wrapper');

const showMoreButton = document.querySelector('.showmore');

const faqIcon = showMoreButton.querySelector('.is-faq-icon');

const buttonText = showMoreButton.querySelector('.button-text-faq');

function toggleItems() {

faqItems.forEach((item, index) => {

if (index < itemsToShow) {

item.style.display = 'flex';

} else {

item.style.display = 'none';

}

});

}

toggleItems();

buttonText.textContent = 'Show More';

showMoreButton.addEventListener('click', function() {

if (buttonText.textContent.trim() === 'Show More') {

itemsToShow = Math.min(faqItems.length, itemsToShow + 5);

buttonText.textContent = 'Show Less';

faqIcon.style.transform = 'rotate(270deg)';

} else {

itemsToShow = 5;

buttonText.textContent = 'Show More';

faqIcon.style.transform = 'rotate(90deg)';

}

toggleItems();

});

});

</script>

<!-- tabs -->

<script>

document.addEventListener('click', function(event) {

// Zkontroluje, zda byl kliknut prvek s třídou `.inside-icon-wrapper`

if (event.target.matches('.inside-icon-wrapper')) {

// Zkontroluje, zda má prvek také třídu `.w--current`

if (event.target.classList.contains('w--current')) {

// Najde prvek s třídou `.empty-tab` a klikne na něj

const emptyTab = document.querySelector('.empty-tab');

if (emptyTab) {

emptyTab.click();

}

}

}

});

</script>

<!-- Pulse -->

<style>

