  <script>
const products = document.querySelectorAll('.hp-products-text');
let hoverTimeout;
function resetStyles() {
    products.forEach(product => {
        const textElement = product.querySelector('.text-80');
        if (textElement) {
            textElement.style.transition = 'color 0.3s linear';
            textElement.style.color = '';
        }
        const arrowElement = product.querySelector('.arrow-wrapper');
        if (arrowElement) {
            arrowElement.style.transition = 'border-color 0.3s linear, color 0.3s linear';
            arrowElement.style.borderColor = '';
            arrowElement.style.color = '';
        }
        const lightGrayElement = product.querySelector('.text-color-light-gray');
        if (lightGrayElement) {
            lightGrayElement.style.transition = 'color 0.3s linear';
            lightGrayElement.style.color = '';
        }
    });
}
products.forEach(product => {
    product.addEventListener('mouseenter', () => {
        clearTimeout(hoverTimeout);
        resetStyles();
        hoverTimeout = setTimeout(() => {
            products.forEach(otherProduct => {
                if (otherProduct !== product) {
                    const textElement = otherProduct.querySelector('.text-80');
                    if (textElement) {
                        textElement.style.transition = 'color 0.3s linear';
                        textElement.style.color = 'white';
                    }
                    const arrowElement = otherProduct.querySelector('.arrow-wrapper');
                    if (arrowElement) {
                        arrowElement.style.transition = 'border-color 0.3s linear, color 0.3s linear';
                        arrowElement.style.borderColor = '#E2E2E2';
                        arrowElement.style.color = 'white';
                    }
                    const lightGrayElement = otherProduct.querySelector('.text-color-light-gray');
                    if (lightGrayElement) {
                        lightGrayElement.style.transition = 'color 0.3s linear';
                        lightGrayElement.style.color = '#CECECE';
                    }
                }
            });
        }, 50);
    });
    product.addEventListener('mouseleave', () => {
        clearTimeout(hoverTimeout);
        resetStyles();
    });
});
</script>
